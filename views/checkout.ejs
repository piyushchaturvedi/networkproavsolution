<!-- Cleaned and fully functional checkout page template with COD and PayPal integration -->
<%- include('_header', { pageTitle: pageTitle, activePage: 'cart' }) %>

<style>
  .checkout-page-container { max-width: 900px; margin: 40px auto; padding: 30px; background: #fff; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
  .checkout-section { margin-bottom: 30px; }
  .section-title { font-size: 1.6rem; font-weight: bold; border-bottom: 2px solid var(--primary-color); padding-bottom: 8px; margin-bottom: 20px; }
  .details-form input, .details-form textarea { width: 100%; padding: 10px; margin-bottom: 15px; border: 1px solid #ddd; border-radius: 5px; }
  .summary-item { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px dashed #ddd; }
  .order-total { text-align: right; font-size: 1.4rem; font-weight: bold; margin-top: 15px; }

  #paypal-button-container { margin-top: 20px; padding: 15px; border: 1px solid var(--primary-color); border-radius: 8px; min-height: 60px; display: flex; justify-content: center; align-items: center; flex-direction: column; }
  #cod-button-container { margin-top: 15px; text-align: center; }
  .cod-confirm-btn { background: var(--primary-color); color: #fff; padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer; }

  /* ✅ FIXED RESPONSIVE DESIGN */
.checkout-page-container {
  max-width: 900px;
  margin: 40px auto;
  padding: 30px;
  background: #fff;
  border-radius: 10px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  font-family: "Poppins", sans-serif;
}

.checkout-section {
  margin-bottom: 30px;
}

/* Section heading underline fix */
.section-title, .checkout-page-container .section-title {
  font-size: 1.6rem;
  font-weight: 600;
  border-bottom: 2px solid #e63946;
  padding-bottom: 8px;
  margin-bottom: 20px;
  color: #222;
}

/* Form layout fix */
.details-form input,
.details-form textarea,
.details-form select {
  width: 100%;
  padding: 12px;
  margin-bottom: 15px;
  border: 1.5px solid #ccc;
  border-radius: 6px;
  font-size: 1rem;
  transition: 0.2s ease;
}

/* Select fields row fix */
.country-state-city-row {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 15px;
}

.country-state-city-row select,
.country-state-city-row input {
  height: 45px;       /* equal height */
  font-size: 1rem;
  padding: 10px;
  border: 1.5px solid #ddd;
  border-radius: 5px;
  width: 100%;
  min-width: 0;
}

/* Fix dropdown alignment issue */
.country-state-city-row select {
  margin: 0;
  width: 100%;
  min-width: 0;
}

/* Hover/Focus UI fix */
.details-form input:focus,
.details-form textarea:focus,
.details-form select:focus {
  border-color: #e63946;
  outline: none;
  box-shadow: 0 0 4px rgba(230,57,70,0.3);
}

/* Order summary fix */
.summary-item {
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px dashed #ddd;
  font-size: 1.05rem;
  color: #333;
}

.order-total {
  text-align: right;
  font-size: 1.35rem;
  font-weight: 600;
  margin-top: 15px;
  color: #000;
}

/* Buttons center alignment fix */
#cod-button-container,
#paypal-button-container {
  display: flex;
  justify-content: center;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  margin-top: 20px;
}

/* COD button styling fix */
.cod-confirm-btn {
  background: #e63946;
  color: #fff;
  padding: 12px 28px;
  border: none;
  border-radius: 6px;
  font-size: 1.1rem;
  font-weight: 500;
  cursor: pointer;
  width: auto;
  min-width: 180px;
  transition: 0.2s ease;
}

.cod-confirm-btn:hover {
  opacity: 0.92;
  transform: translateY(-1px);
}

/* 📱 MOBILE RESPONSIVE */
@media (max-width: 768px) {
  .country-state-city-row {
    grid-template-columns: 1fr; /* Stack on tablet/mobile */
  }
}

@media (max-width: 480px) {
  .checkout-page-container {
    margin: 20px;
    padding: 22px;
  }

  .section-title {
    font-size: 1.4rem;
  }

  .cod-confirm-btn {
    font-size: 1rem;
    padding: 10px 22px;
    min-width: 150px;
  }
}

</style>

<div class="checkout-page-container">

  <!-- Customer Details -->
  <div class="checkout-section">
    <h2 class="section-title">Customer Details</h2>
    <form id="customer-details-form" class="details-form">
      <input type="text" id="firstName" name="firstName" placeholder="First Name" value="<%= customer?.firstName || '' %>" required>
      <input type="text" id="lastName" name="lastName" placeholder="Last Name" value="<%= customer?.lastName || '' %>" required>
      <input type="email" id="email" name="email" placeholder="Email" value="<%= customer?.email || '' %>" required>
      <input type="tel" id="phone" name="phone" placeholder="Phone" value="<%= customer?.phone || '' %>" required>
      <textarea id="address" name="address" placeholder="Billing Address" required><%= customer?.address || '' %></textarea>
      <div class="country-state-city-row">
      <select id="country" name="country" required>
  <option value="">Select Country</option>
</select>

<select id="state" name="state">
  <option value="">Select State</option>
</select>

<input type="text" id="city" name="city" placeholder="Enter your city" required />
</div>
      <input type="text" id="postalCode" name="postalCode" placeholder="Zip Code / Postal Code" value="<%= customer?.postalCode || '' %>" required>
    </form>
  </div>

  <!-- Order Summary -->
  <div class="checkout-section">
    <h2 class="section-title">Order Summary</h2>

    <% if (cart?.length) { %>
      <% cart.forEach(item => { %>
        <div class="summary-item">
          <span><%= item.name %> (x<%= item.quantity %>)</span>
          <span>$<%= (item.price * item.quantity).toFixed(2) %></span>
        </div>
      <% }) %>

      <div class="order-total">Total: $<%= cartTotalPrice %></div>

    <% } else { %>
      <p>Your cart is empty.</p>
    <% } %>
  </div>

  <!-- Payment Section -->
  <div class="checkout-section">
    <h2 class="section-title">Payment</h2>
<div id="form-error-msg" style="display:none; color:#fff; background:#dc3545; padding:10px; border-radius:6px; margin-bottom:15px; text-align:center;"></div>
    <% if (cart?.length) { %>

      <% if (settings.enableCodPayment) { %>
      <div id="cod-button-container">
        <button class="cod-confirm-btn" onclick="submitCodOrder()">Place COD Order</button>
      </div>
      <% } %>

      <div id="paypal-button-container">
        <p id="paypal-loading-message">Loading PayPal...</p>
      </div>

    <% } else { %>
      <p>No items available for checkout.</p>
    <% } %>

  </div>

</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://www.paypal.com/sdk/js?client-id=<%= settings.paypalClientId %>&currency=USD"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
  const countrySelect = document.getElementById("country");
  const stateSelect = document.getElementById("state");
  const citySelect = document.getElementById("city");
  const errorBox = document.getElementById("form-error-msg");
  const form = document.getElementById("customer-details-form");

  // ---------------------------
  // 1. Load country list
  // ---------------------------
  fetch('/location/countries')
    .then(r => r.json())
    .then(list => {
      if (!Array.isArray(list)) throw new Error("Country list invalid");

      countrySelect.innerHTML = `<option value="">-- Select Country --</option>` +
        list.map(c => `<option value="${c}">${c}</option>`).join('');
    })
    .catch(err => {
      console.error(err);
      errorBox.textContent = "Failed to load countries";
    });

  // ---------------------------
  // 2. On Country Change → Load States
  // ---------------------------
  countrySelect.addEventListener('change', () => {
    const countryVal = countrySelect.value;
    stateSelect.innerHTML = `<option>Loading...</option>`;
    citySelect.innerHTML = '';

    fetch(`/location/states?country=${countryVal}`)
      .then(r => r.json())
      .then(list => {
        if (!Array.isArray(list)) throw new Error("State list invalid");
        stateSelect.innerHTML = `<option value="">-- Select State --</option>` +
          list.map(s => `<option value="${s}">${s}</option>`).join('');
        citySelect.innerHTML = `<option value="">-- Select City --</option>`;
      })
      .catch(err => {
        console.error(err);
        errorBox.textContent = "Failed to load states";
      });
  });

  // ---------------------------
  // 3. On State Change → Load Cities
  // ---------------------------
  // stateSelect.addEventListener('change', () => {
  //   const countryVal = countrySelect.value;
  //   const stateVal = stateSelect.value;
  //   citySelect.innerHTML = `<option>Loading...</option>`;

  //   fetch(`/location/cities?country=${countryVal}&state=${stateVal}`)
  //     .then(r => r.json())
  //     .then(list => {
  //       if (!Array.isArray(list)) throw new Error("City list invalid");
  //       citySelect.innerHTML = `<option value="">-- Select City --</option>` +
  //         list.map(ct => `<option value="${ct}">${ct}</option>`).join('');
  //     })
  //     .catch(err => {
  //       console.error(err);
  //       errorBox.textContent = "Failed to load cities";
  //     });
  // });

  cityInput.addEventListener("input", () => {
      errorBox.textContent = "";
    });

  // ---------------------------
  // 4. Save selected details to DB after form submit
  // ---------------------------
  window.submitCustomerDetails = async () => {
    if (!form.checkValidity()) return form.reportValidity();

    const formData = Object.fromEntries(new FormData(form).entries());

    try {
      const resp = await fetch('/checkout/save-details', {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(formData)
      });

      const result = await resp.json();
      if (resp.ok) {
        console.log("Saved to DB ✅", result);
      } else {
        errorBox.textContent = result.error || "Failed to save details";
      }
    } catch (err) {
      console.error("Save Error:", err);
      errorBox.textContent = "Server error while saving details";
    }
  };
});



</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --------------- PAYPAL INTEGRATION ---------------
    const paypalContainer = document.getElementById('paypal-button-container');
    const loadingMessage = document.getElementById('paypal-loading-message');
    const form = document.getElementById('customer-details-form');

    // ---------------- COD ORDER ----------------
    window.submitCodOrder = async () => {
      if (!form.checkValidity()) return form.reportValidity();

      const details = Object.fromEntries(new FormData(form).entries());

      const btn = document.querySelector('.cod-confirm-btn');
      btn.disabled = true; btn.innerText = 'Placing Order...';

      const response = await fetch('/checkout/cod-order', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(details)
      });

      const result = await response.json();
      alert(result.message || result.error);

      if (response.ok) window.location.href = '/checkout/cod-success';
      btn.disabled = false; btn.innerText = 'Place COD Order';
    };

    // --------------- PAYPAL BUTTONS ---------------
    const renderPayPal = () => {
      if (!paypal?.Buttons) return setTimeout(renderPayPal, 300);

      loadingMessage?.remove();

      paypal.Buttons({
        createOrder: async () => {
          if (!form.checkValidity()) {
            form.reportValidity();
            throw new Error('Invalid customer details');
          }

          await fetch('/checkout/save-details', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(new FormData(form).entries()))
          });

          const res = await fetch('/api/orders', { method: 'POST' });
          const data = await res.json();
          return data.orderID;
        },

        onApprove: async (data) => {
          const res = await fetch(`/api/orders/${data.orderID}/capture`, {
            method: 'POST'
          });
          const result = await res.json();
          if (result.redirectUrl) {
            window.location.href = result.redirectUrl;
          } else {
            alert("Payment capture failed");
          }
        },
        onError: (err) => alert('PayPal Error: ' + err.message)

      }).render('#paypal-button-container');
    };

    renderPayPal();
  });
</script>

<%- include('_footer') %>
