<style>
  /* 1. Set the container to flexbox for proper alignment */
  .products_search_main {
    width: 100%;
    margin-left: 0px !important;
    display: flex;
    /* ADDED/UPDATED */
    align-items: center;
    /* ADDED/UPDATED: Ensures vertical centering */
  }

  /* 2. Style the input field for merging */
  .products_search_header {
    width: 70%;
    padding-block: 8px;
    padding-inline: 15px;
    border: 1px solid #f04444;
    color: #000000;
    border-radius: 10px 0 0 10px;
    border-right: none;
    /* ADDED/UPDATED: Removes the right border for merging */
    /* Ensure no extra vertical spacing */
    margin-bottom: 0;
  }

  /* 3. Style the button for merging */
  .products_search_submit_btn {
    width: 30%;
    padding-inline: 15px;
    padding-block: 9px;
    border-radius: 0 10px 10px 0;
    border: 1px solid #f04444;
    /* Match input border */
    border-left: none;
    /* ADDED/UPDATED: Removes the left border for merging */
    /* Ensure no extra vertical spacing */
    margin-bottom: 0 !important;
    /* Force removal of any inherited margin */
    height: 38px;
    /* Consistent height with the input field */
    box-sizing: border-box;
    /* Crucial for correct height calculation */
  }

  /* ===== STICKY STRIP ===== */
  .top-offer-strip {
    background: #f7f7f7;
    border-bottom: 1px solid #e5e5e5;
    padding: 6px 0;
    z-index: 9999;
  }

  .sticky-strip {
    position: sticky;
    top: 0;
  }

  /* Inner container */
  .offer-inner {
    max-width: 1600px;
    margin: auto;
    padding: 0 15px;
    display: flex;
    align-items: center;
    gap: 14px;
    margin-left: 14%;
  }

  /* Green pill button */
  .auth-green-btn {
    background: #0b0c0b;
    color: #ffffff;
    font-size: 12.5px;
    font-weight: 600;
    padding: 4px 14px 4px 10px;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  /* ✔ icon */
  .check-icon-green {
    background: #ffffff;
    color: #22c55e;
    font-size: 11px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Right text */
  .offer-right {
    font-size: 13px;
    color: #333;
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: 220px;
  }

  /* Black coupon tag */
  .coupon-black {
    background: #111;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.5px;
  }

  /* Subtle animation */
  .offer-right {
    animation: slideFade 3.5s infinite;
  }

  @keyframes slideFade {
    0% {
      opacity: 0;
      transform: translateX(-6px);
    }

    20% {
      opacity: 1;
      transform: translateX(0);
    }

    80% {
      opacity: 1;
    }

    100% {
      opacity: 0;
      transform: translateX(6px);
    }
  }

  /* Mobile friendly */
  @media (max-width: 768px) {
    .offer-inner {
      flex-wrap: wrap;
      gap: 6px;
    }

    .offer-right {
      font-size: 12px;
    }
  }


  /* ==============================
   FIX: TOP OFFER STRIP RESPONSIVE
============================== */

  /* Desktop only */
  @media (min-width: 992px) {
    .offer-inner {
      margin-left: 14%;
    }

    .offer-right {
      margin-left: 220px;
    }
  }

  /* Mobile + Tablet */
  @media (max-width: 991px) {

    .top-offer-strip,
    .sticky-strip {
      width: 100%;
      max-width: 100%;
      overflow-x: hidden;
    }

    .offer-inner {
      margin-left: 0 !important;
      /* 🔑 FIX 1 */
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 6px;
      padding: 8px 10px;
    }

    .offer-left {
      width: 100%;
      display: flex;
      justify-content: center;
    }

    .offer-right {
      margin-left: 0 !important;
      /* 🔑 FIX 2 */
      width: 100%;
      white-space: normal;
      /* 🔑 FIX 3 */
      word-break: break-word;
      font-size: 12px;
      line-height: 1.4;
      justify-content: center;
      flex-wrap: wrap;
    }

    .coupon-black {
      margin-top: 4px;
      display: inline-block;
    }
  }



  .auth-green-btn:hover .check-icon-green {
    transform: scale(1.25);
    box-shadow: 0 0 0 6px rgba(40, 167, 69, 0.2);
  }
</style>

