<%- include('_header', { pageTitle: pageTitle, activePage: 'orders' }) %>

<style>
  /* Admin Order History Styling */
  .admin-order-history-dashboard {
    max-width: 1200px;
    margin: 40px auto;
    padding: 20px;
    background-color: #fff;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    border-radius: 8px;
  }

  .admin-order-history-dashboard h1 {
    text-align: center;
    margin-bottom: 30px;
    color: #333;
  }

  .order-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
  }

  .order-table th,
  .order-table td {
    border: 1px solid #ddd;
    padding: 12px;
    text-align: left;
    vertical-align: top;
  }

  .order-table th {
    background-color: #f2f2f2;
    font-weight: bold;
  }

  .order-table tbody tr:nth-child(even) {
    background-color: #f9f9f9;
  }

  .order-table tbody tr:hover {
    background-color: #f1f1f1;
  }

  .order-items-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.9em;
  }

  .order-items-list li {
    margin-bottom: 5px;
  }

  /* Responsive Table */
  @media (max-width: 768px) {
    .admin-order-history-dashboard {
      margin: 20px auto;
      padding: 10px;
    }

    .order-table,
    .order-table thead,
    .order-table tbody,
    .order-table th,
    .order-table td,
    .order-table tr {
      display: block;
    }

    .order-table thead tr {
      position: absolute;
      top: -9999px;
      left: -9999px;
    }

    .order-table tr {
      margin: 0 0 1rem 0;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 10px;
    }

    .order-table td {
      border: none;
      border-bottom: 1px solid #eee;
      position: relative;
      padding-left: 50%;
      text-align: right;
    }

    .order-table td:before {
      position: absolute;
      top: 12px;
      left: 6px;
      width: 45%;
      padding-right: 10px;
      white-space: nowrap;
      content: attr(data-label);
      font-weight: bold;
      text-align: left;
    }

    .order-table td:last-child {
      border-bottom: 0;
    }
  }
</style>

<div class="admin-order-history-dashboard">
  <h1>Order History</h1>

  <table class="order-table">
    <thead>
      <tr>
        <th>Order ID (PayPal)</th>
        <th>Customer Name</th>
        <th>Customer Email</th>
        <th>Total Amount</th>
        <th>Items</th>
        <th>Shipping Details</th>
        <th>Payment Status</th>
        <th>Completion Status</th>
        <th>Order Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (orders && orders.length > 0) { %>
      <% orders.forEach(order => { %>
      <tr>
        <td data-label="Order ID"><%= order.paypalOrderId %></td>
        <td data-label="Customer Name"><%= order.customerName %></td>
        <td data-label="Customer Email"><%= order.customerEmail %></td>
        <td data-label="Total Amount">$<%= order.totalAmount.toFixed(2) %> <%= order.currency %></td>
        <td data-label="Items">
          <ul class="order-items-list">
            <% order.items.forEach(item => { %>
            <li><%= item.name %> (x<%= item.quantity %>) - $<%= item.price.toFixed(2) %></li>
            <% }); %>
          </ul>
        </td>
        <td data-label="Shipping Details">

          <% const s = order.shippingAddress || {}; %>

          <div style="
            background:#f9fafb;
            padding:10px 12px;
            border-radius:8px;
            font-size:13px;
            line-height:1.5;
            min-width:200px;
            ">

            <strong>
              <%= s.fullName || s.firstName + " " + s.lastName || order.customerName || "Guest" %>
            </strong><br>

            <span style="color:#555">
              <%= s.address || order.customerAddress || "" %>
            </span><br>

            <% if(s.city || order.customercity){ %>
            <%= s.city || order.customercity %>,
            <% } %>

            <% if(s.state || order.customerstate){ %>
            <%= s.state || order.customerstate %>
            <% } %>

            <% if(s.postalCode || order.customerpostalCode){ %>
            - <%= s.postalCode || order.customerpostalCode %>
            <% } %>

            <br>

            <%= s.country || order.customercountry || "" %>

            <hr style="margin:6px 0">

            📧 <%= s.email || order.customerEmail || "N/A" %><br>
            📞 <%= s.phone || order.customerPhone || "N/A" %>

          </div>

        </td>
        <td data-label="Status"><%= order.status %></td>
        <td data-label="OrderCompleteStatus"><%= order.OrderCompleteStatus %></td>

        <td data-label="Order Date"><%= order.createdAt.toLocaleDateString() %>
          <%= order.createdAt.toLocaleTimeString() %></td>
        <td data-label="Actions">
          <button type="button" class="btn btn-sm btn-info" 
                data-bs-toggle="modal" 
                data-bs-target="#emailModal" 
                data-email="<%= s.email || order.customerEmail || 'N/A' %>" data-orderid="<%= order._id %>" 
                data-orderid="<%= order._id %>"
                data-total="<%= order.totalAmount %>"
                data-items='<%= JSON.stringify(order.items) %>'
                data-shippingAddress='<%= JSON.stringify(order.shippingAddress) %>'>
                <i class="fas fa-envelope"></i> Send Email
          </button>
          <% if (order.OrderCompleteStatus !== 'Completed') { %>
          <form action="/admin/orders/<%= order._id %>" method="POST" style="display:inline;">
            <button type="submit" class="btn btn-sm btn-success">Mark Complete</button>
          </form>
          <% } %>

        </td>
      </tr>
      <% }); %>
      <% } else { %>
      <tr>
        <td colspan="7" style="text-align: center;">No orders found.</td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('_footer') %>


<div class="modal fade" id="emailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Send Order Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/send-email" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">To:</label>
                        <input type="email" name="toEmail" id="modalEmail" class="form-control" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Subject:</label>
                        <input type="text" name="subject" id="modalSubject" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message:</label>
                        <textarea name="message" id="modalMessage" class="form-control" rows="8" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Send Email</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const emailModal = document.getElementById('emailModal');
    emailModal.addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;
        
        // Data attributes se information nikalna
        const email = button.getAttribute('data-email');
        const orderId = button.getAttribute('data-orderid');
        const total = button.getAttribute('data-total');
        const items = JSON.parse(button.getAttribute('data-items'));
        const shippingAddress = JSON.parse(button.getAttribute('data-shippingAddress'));

        const modalEmailInput = emailModal.querySelector('#modalEmail');
        const modalSubjectInput = emailModal.querySelector('input[name="subject"]');
        const modalMessageTextarea = emailModal.querySelector('textarea[name="message"]');

        // Fields fill karna
        modalEmailInput.value = email;
        modalSubjectInput.value = `Order Update: ID #${orderId} - NetworkProAVSolution`;

        // Multiple Items ki list format karna
        let itemsList = "";
        items.forEach(item => {
            itemsList += `- ${item.name} (x${item.quantity}) - $${item.price.toFixed(2)}\n`;
        });

        // Aapka bataya hua Message Template
        const fullMessage = `Hello ${shippingAddress?.firstName || 'Customer'} ${shippingAddress?.lastName || ''},

Thank you for choosing NetworkProAVSolution.

Your order has been successfully received and is currently being processed.

Order Details:
Order ID: #${orderId}

Items:
${itemsList}

Total Amount: $${total}

Our team will review and process your order shortly. You will receive another notification once your order is confirmed or shipped.

If you have any questions, please feel free to contact us.

Thank you for trusting NetworkProAVSolution.`;

        modalMessageTextarea.value = fullMessage;
    });
</script>